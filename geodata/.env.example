DATABASE_URL=postgresql://geodata:geodata@localhost:5432/geodata
REDIS_URL=redis://localhost:6379/0
TILES_DIR=/tmp/geodata/tiles

# Cloudflare R2 (prod only)
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=geodata-tiles

# Geocoding
GEOCODIO_API_KEY=

# Phase 2: Financial enrichment
# CMS HCRIS — find ZIP URLs at:
#   HHA: https://www.cms.gov/data-research/statistics-trends-and-reports/medicare-provider-cost-report/home-health-agency
#   Hospice: https://www.cms.gov/data-research/statistics-trends-and-reports/medicare-provider-cost-report/hospice
HCRIS_HHA_URL=
HCRIS_HOSPICE_URL=
HCRIS_YEAR=2022

# CA HCAI Annual Financial Disclosure — find XLSX URLs at:
#   https://hcai.ca.gov/data-and-reports/research-data/annual-financial-data/
HCAI_SNF_URL=
HCAI_YEAR=2022
